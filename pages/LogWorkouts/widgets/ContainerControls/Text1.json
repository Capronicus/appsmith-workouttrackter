  "text": "{{ (() => {\n  const d = PreviousWorkoutNote.data?.[0]?.completed_at;\n  if (!d) return \"\";\n  const days = moment().startOf('day').diff(moment(d).startOf('day'), 'days');\n  let label;\n  if (days === 0) label = \"Today\";\n  else if (days === 1) label = \"Yesterday\";\n  else if (days <= 7) label = days + \" days ago\";\n  else label = moment(d).format(\"DD/MM/YYYY\");\n  return label + \" :\";\n})() }}",
